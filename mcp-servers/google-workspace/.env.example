# Google Workspace MCP Server Configuration

# ============================================================
# OAuth 2.0 Credentials (REQUIRED)
# ============================================================

# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here

# Optional: OAuth Redirect URI
# Default: http://localhost:8080/
GOOGLE_REDIRECT_URI=http://localhost:8080/

# OAuth mode: manual | local
# manual: 不起本地回调服务，授权后手动粘贴浏览器地址栏 URL（WSL 推荐）
# local:  起本地回调服务自动完成授权
OAUTH_MODE=manual

# ============================================================
# Optional: Configuration
# ============================================================

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Enable tools (comma-separated list, empty means all tools)
# Example: ENABLED_TOOLS=gmail_get_messages,calendar_create_event
ENABLED_TOOLS=
