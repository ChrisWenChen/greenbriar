# Telegram Bot Token
# 从 @BotFather 获取
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# OpenCode Server 配置（默认本机 4096 端口）
OPENCODE_SERVER=http://127.0.0.1:4096

# OpenCode Server 密码（如果设置了的话）
OPENCODE_SERVER_PASSWORD=

# Webhook URL（留空则使用 polling 模式，WSL/本地开发推荐 polling）
WEBHOOK_URL=

# Webhook 监听端口（仅 webhook 模式使用）
PORT=8443
